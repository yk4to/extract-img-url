{
  "name": "extract-img-url",
  "version": "0.1.3",
  "description": "Extract first image url from markdown",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "prepare": "npm run build"
  },
  "author": "yk4to",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "markdown",
    "url",
    "extract"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  }
}
